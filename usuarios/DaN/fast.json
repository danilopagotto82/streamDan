          "description": "\n{stream.title::exists[\"🎬 {stream.title::title} \"||\"\"]}{stream.year::exists[\"({stream.year})\"||\"\"]}\n\n{stream.formattedSeasons::exists[\"🍂 {stream.formattedSeasons} \"||\"\"]}{stream.formattedEpisodes::exists[\"🎞️ {stream.formattedEpisodes}\\n\"||\"\\n\"]}{stream.seadexBest::istrue[\"🎚️ Best Release\\n\"||\"\"]}{stream.duration::>0[\"⏱️ {stream.duration::time}\\n\"||\"\"]}\n\n{stream.filename::~extended[\"⏩ Versão Estendida \"||\"\"]}{stream.filename::~theatrical[\"🎭 Versão de Cinema \"||\"\"]}{stream.filename::~director[\"🎬 Versão do Diretor \"||\"\"]}{stream.visualTags::exists[\"✨ Imagem: {stream.visualTags::join(' • ')}\\n\"||\"\"]}{stream.audioTags::exists[\"🎧 Áudio: {stream.audioTags::join(' • ')}\\n\"||\"\"]}{stream.languageEmojis::exists[\"🌎 Idiomas: {stream.languageEmojis::join(' • ')}\\n\"||\"\"]}{stream.subtitleEmojis::exists[\"🔤 Legendas: {stream.subtitleEmojis::join(' • ')}\\n\"||\"\"]}{stream.size::exists[\"💾 Tamanho: {stream.size::bytes}\"||\"\"]}\n\n{stream.releaseGroup::exists[\"📁 Grupo: {stream.releaseGroup}\"||\"\"]}{stream.indexer::exists::and::stream.type::=usenet[\" · {stream.indexer}\"||\"\"]}"
        }
      }
